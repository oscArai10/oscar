# ============================================================
# oscAr contracts — OWNER-ONLY secrets. Copy to contracts/.env.
# This is the ONLY place the factory deployer key ever lives.
# NEVER put this key in the web app or on Vercel.
# ============================================================

# The business wallet that deploys and owns the 10 factory contracts.
# It signs each deploy and funds the gas (~$50-150 total, mostly Ethereum).
DEPLOYER_PRIVATE_KEY=

# Alchemy key — builds RPC URLs for all 10 chains + testnets.
ALCHEMY_API_KEY=

# Etherscan V2 multichain key (one key verifies on all supported explorers).
ETHERSCAN_API_KEY=

# Fee collection: the flat per-deploy fee (in native coin, whole units e.g.
# "0.01") and the wallet it is forwarded to. Set per-chain at deploy time;
# these are the defaults the deploy script reads.
FEE_WALLET_ADDRESS=
DEPLOY_FEE_ETHEREUM=0.01
DEPLOY_FEE_DEFAULT=0.01
