# ============================================================
# oscAr — environment variables
# Copy to .env.local and fill in real values. NEVER commit .env files.
# ALL keys are server-side only unless prefixed NEXT_PUBLIC_.
# ============================================================

# --- oscAr AI (never exposed publicly; branded "oscAr AI") ---
ANTHROPIC_API_KEY=sk-ant-placeholder            # Primary brain (Claude API)
OPENAI_API_KEY=sk-placeholder                   # Silent failover (GPT-4o)

# --- RPC (Alchemy — all 10 chains + testnets) ---
ALCHEMY_API_KEY=placeholder

# --- Database (Supabase / PostgreSQL) ---
NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder
SUPABASE_SERVICE_ROLE_KEY=placeholder           # server-side only, bypasses RLS

# --- Rate limiting (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=https://placeholder.upstash.io
UPSTASH_REDIS_REST_TOKEN=placeholder

# --- Wallet connection (WalletConnect Cloud project) ---
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=placeholder

# --- Slither audit microservice (Railway/Fly.io) ---
SLITHER_SERVICE_URL=https://placeholder.up.railway.app
SLITHER_SERVICE_API_KEY=placeholder             # internal key, server-to-server only

# --- Payments (Paddle OR Lemon Squeezy as merchant of record) ---
PADDLE_API_KEY=placeholder
PADDLE_WEBHOOK_SECRET=placeholder
PADDLE_ENVIRONMENT=sandbox                      # "sandbox" or "production"
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=placeholder     # Paddle.js client-side token (public, safe to expose)
NEXT_PUBLIC_PADDLE_PRICE_ID_PRO=placeholder     # Price ID for the Pro plan, from the Paddle dashboard
# LEMONSQUEEZY_API_KEY=placeholder
# LEMONSQUEEZY_WEBHOOK_SECRET=placeholder

# --- Auth / sessions ---
SESSION_SECRET=generate-a-long-random-string-here
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- oscAr CORE (admin) security layers ---
OSCAR_CORE_OWNER_EMAIL=placeholder@example.com
OSCAR_CORE_SECRET_KEY=long-random-secret-entered-on-every-core-login
OSCAR_CORE_ALLOWED_IPS=127.0.0.1                # comma-separated allowlist

# --- On-chain fee collection ---
FEE_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
# NOTE: the factory-contract DEPLOYER private key lives ONLY in contracts/.env
# on the owner's machine — never in this app, never on Vercel.
